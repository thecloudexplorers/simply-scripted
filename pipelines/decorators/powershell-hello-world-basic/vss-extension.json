{
  "manifestVersion": 1,
  "id": "powershell-hello-world-decorator",
  "publisher": "DevJevNL",
  "version": "1.0.0",
  "name": "PowerShell Hello .NET Assemble basic Decorator",
  "public": false,
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "description": "This is a sample of an Azure Pipeline Decorator which executes before any other task",
  "categories": [
    "Azure Pipelines"
  ],
  "contributions": [
    {
      "id": "powershell-required-task",
      "type": "ms.azure-pipelines.pipeline-decorator",
      "targets": [
        "ms.azure-pipelines-agent-job.pre-job-tasks"
      ],
      "properties": {
        "template": "run-powershell-script.yml"
      }
    }
  ],
  "files": [
    {
      "path": "run-powershell-script.yml",
      "addressable": true,
      "contentType": "text/plain"
    }
  ]
}
